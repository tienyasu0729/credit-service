<!-- BACK BUTTON -->
<div class="mb-5 sm:mb-6">
  <a href="/admin" class="inline-flex items-center gap-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-800 cursor-pointer group">
    <svg class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
    </svg>
    Quay lại Bảng điều khiển
  </a>
</div>

<!-- DETAIL CARD -->
<div class="bg-white shadow-sm rounded-xl border border-slate-200 mb-6 sm:mb-8 overflow-hidden">
  <!-- Card Header -->
  <div class="px-4 sm:px-6 py-4 sm:py-5 border-b border-slate-200 bg-slate-50/60">
    <!-- Mobile: stack, Desktop: row -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div class="min-w-0">
        <h1 class="text-lg sm:text-xl font-bold text-slate-900">Chi tiết hồ sơ</h1>
        <p class="mt-0.5 text-xs text-slate-500 font-mono truncate">
          ID: <%= application.id %>
        </p>
      </div>
      <div class="flex-shrink-0">
        <% if (application.status === 'PENDING') { %>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-semibold rounded-full bg-amber-100 text-amber-800 border border-amber-200">
            <span class="w-2 h-2 bg-amber-500 rounded-full animate-pulse"></span>
            CHỜ XỬ LÝ
          </span>
        <% } else if (application.status === 'APPROVED') { %>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-semibold rounded-full bg-emerald-100 text-emerald-800 border border-emerald-200">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            ĐÃ PHÊ DUYỆT
          </span>
        <% } else { %>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-semibold rounded-full bg-red-100 text-red-800 border border-red-200">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" /></svg>
            ĐÃ TỪ CHỐI
          </span>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Info list: 2-col grid trên desktop, stacked trên mobile -->
  <dl class="divide-y divide-slate-100">
    <div class="px-4 sm:px-6 py-3 sm:py-4 grid grid-cols-1 sm:grid-cols-3 sm:gap-4 items-start">
      <dt class="text-sm font-medium text-slate-500 mb-1 sm:mb-0">Tên khách hàng</dt>
      <dd class="text-sm font-semibold text-slate-900 sm:col-span-2"><%= application.customerName %></dd>
    </div>
    <div class="px-4 sm:px-6 py-3 sm:py-4 grid grid-cols-1 sm:grid-cols-3 sm:gap-4 items-start bg-slate-50/50">
      <dt class="text-sm font-medium text-slate-500 mb-1 sm:mb-0">CCCD</dt>
      <dd class="text-sm font-mono text-slate-900 sm:col-span-2"><%= application.cccd %></dd>
    </div>
    <div class="px-4 sm:px-6 py-3 sm:py-4 grid grid-cols-1 sm:grid-cols-3 sm:gap-4 items-start">
      <dt class="text-sm font-medium text-slate-500 mb-1 sm:mb-0">Số điện thoại</dt>
      <dd class="text-sm text-slate-900 sm:col-span-2"><%= application.phone %></dd>
    </div>
    <div class="px-4 sm:px-6 py-3 sm:py-4 grid grid-cols-1 sm:grid-cols-3 sm:gap-4 items-start bg-slate-50/50">
      <dt class="text-sm font-medium text-slate-500 mb-1 sm:mb-0">Số tiền vay</dt>
      <dd class="text-sm sm:col-span-2">
        <span class="text-base sm:text-lg font-bold text-indigo-700">
          <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(application.amount) %>
        </span>
      </dd>
    </div>
    <div class="px-4 sm:px-6 py-3 sm:py-4 grid grid-cols-1 sm:grid-cols-3 sm:gap-4 items-start">
      <dt class="text-sm font-medium text-slate-500 mb-1 sm:mb-0">Kỳ hạn</dt>
      <dd class="text-sm text-slate-900 sm:col-span-2"><%= application.term %> tháng</dd>
    </div>
    <% if (application.externalId) { %>
    <div class="px-4 sm:px-6 py-3 sm:py-4 grid grid-cols-1 sm:grid-cols-3 sm:gap-4 items-start bg-slate-50/50">
      <dt class="text-sm font-medium text-slate-500 mb-1 sm:mb-0">Mã hệ thống ngoài</dt>
      <dd class="text-sm font-mono text-slate-900 sm:col-span-2"><%= application.externalId %></dd>
    </div>
    <% } %>

    <!-- Documents -->
    <div class="px-4 sm:px-6 py-3 sm:py-4 grid grid-cols-1 sm:grid-cols-3 sm:gap-4 items-start">
      <dt class="text-sm font-medium text-slate-500 mb-2 sm:mb-0">Tài liệu đính kèm</dt>
      <dd class="sm:col-span-2">
        <ul role="list" class="border border-slate-200 rounded-lg divide-y divide-slate-200 overflow-hidden">
          <li class="flex items-center justify-between px-3 py-2.5 text-sm bg-white hover:bg-slate-50 transition-colors">
            <div class="flex items-center gap-2 min-w-0">
              <svg class="flex-shrink-0 h-4 w-4 text-slate-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M15.621 4.379a3 3 0 00-4.242 0l-7 7a3 3 0 004.241 4.243h.001l.497-.5a.75.75 0 011.064 1.057l-.498.501-.002.002a4.5 4.5 0 01-6.364-6.364l7-7a4.5 4.5 0 016.368 6.36l-3.455 3.553A2.625 2.625 0 119.52 9.52l3.45-3.451a.75.75 0 111.061 1.06l-3.45 3.451a1.125 1.125 0 001.587 1.595l3.454-3.553a3 3 0 000-4.242z" clip-rule="evenodd" />
              </svg>
              <span class="truncate font-medium text-slate-700">Ảnh CCCD</span>
            </div>
            <a href="<%= application.cccdUrl %>" target="_blank" rel="noopener noreferrer" class="flex-shrink-0 ml-3 text-xs font-semibold text-indigo-600 hover:text-indigo-800 cursor-pointer" onclick="event.stopPropagation()">
              Xem &rarr;
            </a>
          </li>
          <% if (application.incomeProofUrl) { %>
          <li class="flex items-center justify-between px-3 py-2.5 text-sm bg-white hover:bg-slate-50 transition-colors">
            <div class="flex items-center gap-2 min-w-0">
              <svg class="flex-shrink-0 h-4 w-4 text-slate-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M15.621 4.379a3 3 0 00-4.242 0l-7 7a3 3 0 004.241 4.243h.001l.497-.5a.75.75 0 011.064 1.057l-.498.501-.002.002a4.5 4.5 0 01-6.364-6.364l7-7a4.5 4.5 0 016.368 6.36l-3.455 3.553A2.625 2.625 0 119.52 9.52l3.45-3.451a.75.75 0 111.061 1.06l-3.45 3.451a1.125 1.125 0 001.587 1.595l3.454-3.553a3 3 0 000-4.242z" clip-rule="evenodd" />
              </svg>
              <span class="truncate font-medium text-slate-700">Chứng minh thu nhập</span>
            </div>
            <a href="<%= application.incomeProofUrl %>" target="_blank" rel="noopener noreferrer" class="flex-shrink-0 ml-3 text-xs font-semibold text-indigo-600 hover:text-indigo-800 cursor-pointer" onclick="event.stopPropagation()">
              Xem &rarr;
            </a>
          </li>
          <% } %>
          <% if (application.contractUrl) { %>
          <li class="flex items-center justify-between px-3 py-2.5 text-sm bg-white hover:bg-slate-50 transition-colors">
            <div class="flex items-center gap-2 min-w-0">
              <svg class="flex-shrink-0 h-4 w-4 text-slate-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M15.621 4.379a3 3 0 00-4.242 0l-7 7a3 3 0 004.241 4.243h.001l.497-.5a.75.75 0 011.064 1.057l-.498.501-.002.002a4.5 4.5 0 01-6.364-6.364l7-7a4.5 4.5 0 016.368 6.36l-3.455 3.553A2.625 2.625 0 119.52 9.52l3.45-3.451a.75.75 0 111.061 1.06l-3.45 3.451a1.125 1.125 0 001.587 1.595l3.454-3.553a3 3 0 000-4.242z" clip-rule="evenodd" />
              </svg>
              <span class="truncate font-medium text-slate-700">Hợp đồng</span>
            </div>
            <a href="<%= application.contractUrl %>" target="_blank" rel="noopener noreferrer" class="flex-shrink-0 ml-3 text-xs font-semibold text-indigo-600 hover:text-indigo-800 cursor-pointer" onclick="event.stopPropagation()">
              Xem &rarr;
            </a>
          </li>
          <% } %>
        </ul>
      </dd>
    </div>

    <!-- Rejection info nếu đã từ chối -->
    <% if (application.status === 'REJECTED') { %>
    <div class="px-4 sm:px-6 py-3 sm:py-4 grid grid-cols-1 sm:grid-cols-3 sm:gap-4 items-start bg-red-50/60">
      <dt class="text-sm font-medium text-red-600 mb-1 sm:mb-0">Lý do từ chối</dt>
      <dd class="text-sm font-bold text-red-800 sm:col-span-2">
        <%= reasonLabels[application.reasonCode] || application.reasonCode %>
      </dd>
    </div>
    <% if (application.note) { %>
    <div class="px-4 sm:px-6 py-3 sm:py-4 grid grid-cols-1 sm:grid-cols-3 sm:gap-4 items-start bg-red-50/40">
      <dt class="text-sm font-medium text-red-600 mb-1 sm:mb-0">Ghi chú của Admin</dt>
      <dd class="text-sm text-red-700 sm:col-span-2 leading-relaxed"><%= application.note %></dd>
    </div>
    <% } %>
    <% } %>
  </dl>
</div>

<!-- DECISION PANEL (chỉ hiện khi PENDING) -->
<% if (application.status === 'PENDING') { %>
<div class="bg-white shadow-sm rounded-xl border border-slate-200 overflow-hidden">
  <div class="px-4 sm:px-6 py-4 sm:py-5">
    <h2 class="text-base sm:text-lg font-bold text-slate-900 mb-4 sm:mb-5">Quyết định phê duyệt</h2>

    <!-- Action buttons: stack trên mobile, row trên sm -->
    <div class="flex flex-col sm:flex-row gap-3">
      <!-- APPROVE FORM -->
      <form action="/admin/<%= application.id %>/action" method="POST" class="flex-1 sm:flex-none">
        <input type="hidden" name="action" value="APPROVE">
        <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-5 py-2.5 border border-transparent font-semibold rounded-lg text-white bg-emerald-600 hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 text-sm shadow-sm cursor-pointer transition-colors duration-150">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          Phê duyệt hồ sơ
        </button>
      </form>

      <!-- REJECT TOGGLE BUTTON -->
      <button
        type="button"
        id="toggleRejectBtn"
        onclick="document.getElementById('rejectForm').classList.toggle('hidden'); this.classList.toggle('bg-slate-100');"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-5 py-2.5 border border-red-300 font-semibold rounded-lg text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 text-sm shadow-sm cursor-pointer transition-colors duration-150">
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" /></svg>
        Từ chối hồ sơ...
      </button>
    </div>

    <!-- REJECT FORM (hidden by default) -->
    <form id="rejectForm" action="/admin/<%= application.id %>/action" method="POST" class="hidden mt-5 sm:mt-6 border-t border-slate-200 pt-5 sm:pt-6">
      <input type="hidden" name="action" value="REJECT">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <!-- Reason Code: full width trên mobile, half trên sm -->
        <div class="sm:col-span-1">
          <label for="reasonCode" class="block text-sm font-medium text-slate-700 mb-1.5">
            Lý do từ chối <span class="text-red-500">*</span>
          </label>
          <select
            id="reasonCode"
            name="reasonCode"
            required
            class="block w-full rounded-lg border border-slate-300 bg-white py-2 px-3 text-sm text-slate-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 cursor-pointer">
            <option value="">Chọn lý do...</option>
            <% reasonCodes.forEach(code => { %>
              <option value="<%= code %>"><%= reasonLabels[code] %></option>
            <% }) %>
          </select>
        </div>

        <!-- Note: full width -->
        <div class="sm:col-span-2">
          <label for="note" class="block text-sm font-medium text-slate-700 mb-1.5">
            Ghi chú thêm <span class="text-slate-400 font-normal">(Không bắt buộc)</span>
          </label>
          <textarea
            id="note"
            name="note"
            rows="3"
            placeholder="Nhập ghi chú nếu cần thiết..."
            class="block w-full rounded-lg border border-slate-300 bg-white py-2 px-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 resize-none"></textarea>
        </div>
      </div>

      <div class="mt-4 flex flex-col sm:flex-row gap-3">
        <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-5 py-2.5 border border-transparent font-semibold rounded-lg text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 text-sm shadow-sm cursor-pointer transition-colors duration-150">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.519.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 00-1.5.06l.3 7.5a.75.75 0 101.5-.06l-.3-7.5zm4.34.06a.75.75 0 10-1.5-.06l-.3 7.5a.75.75 0 101.5.06l.3-7.5z" clip-rule="evenodd" /></svg>
          Xác nhận từ chối
        </button>
        <button type="button" onclick="document.getElementById('rejectForm').classList.add('hidden'); document.getElementById('toggleRejectBtn').classList.remove('bg-slate-100');" class="w-full sm:w-auto inline-flex items-center justify-center px-5 py-2.5 border border-slate-300 font-medium rounded-lg text-slate-700 bg-white hover:bg-slate-50 text-sm cursor-pointer transition-colors duration-150">
          Huỷ
        </button>
      </div>
    </form>
  </div>
</div>
<% } %>

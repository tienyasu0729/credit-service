<div class="mb-6">
  <a href="/admin" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; Quay lại Bảng điều khiển</a>
</div>

<div class="bg-white shadow overflow-hidden sm:rounded-lg mb-8">
  <div class="px-4 py-5 sm:px-6 flex justify-between items-center border-b border-gray-200">
    <div>
      <h3 class="text-lg leading-6 font-medium text-gray-900">Chi tiết hồ sơ</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">Mã hồ sơ: <%= application.id %></p>
    </div>
    <div>
      <% if (application.status === 'PENDING') { %>
        <span class="px-3 py-1 inline-flex text-sm leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">CHỜ XỬ LÝ</span>
      <% } else if (application.status === 'APPROVED') { %>
        <span class="px-3 py-1 inline-flex text-sm leading-5 font-semibold rounded-full bg-green-100 text-green-800">ĐÃ PHÊ DUYỆT</span>
      <% } else { %>
        <span class="px-3 py-1 inline-flex text-sm leading-5 font-semibold rounded-full bg-red-100 text-red-800">ĐÃ TỪ CHỐI</span>
      <% } %>
    </div>
  </div>
  <div class="px-4 py-5 sm:p-0">
    <dl class="sm:divide-y sm:divide-gray-200">
      <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Tên khách hàng</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= application.customerName %></dd>
      </div>
      <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 bg-gray-50">
        <dt class="text-sm font-medium text-gray-500">CCCD</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= application.cccd %></dd>
      </div>
      <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Số điện thoại</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= application.phone %></dd>
      </div>
      <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 bg-gray-50">
        <dt class="text-sm font-medium text-gray-500">Số tiền vay</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2 font-bold">
          <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(application.amount) %>
        </dd>
      </div>
      <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Kỳ hạn</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= application.term %> tháng</dd>
      </div>
      <% if (application.externalId) { %>
      <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 bg-gray-50">
        <dt class="text-sm font-medium text-gray-500">Mã hệ thống ngoài (External ID)</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= application.externalId %></dd>
      </div>
      <% } %>
      <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Tài liệu đính kèm</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
          <ul role="list" class="border border-gray-200 rounded-md divide-y divide-gray-200">
            <li class="pl-3 pr-4 py-3 flex items-center justify-between text-sm">
              <div class="w-0 flex-1 flex items-center">
                <svg class="flex-shrink-0 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M8 4a3 3 0 00-3 3v4a5 5 0 0010 0V7a1 1 0 112 0v4a7 7 0 11-14 0V7a5 5 0 0110 0v4a3 3 0 11-6 0V7a1 1 0 012 0v4a1 1 0 102 0V7a3 3 0 00-3-3z" clip-rule="evenodd" />
                </svg>
                <span class="ml-2 flex-1 w-0 truncate"> Ảnh CCCD </span>
              </div>
              <div class="ml-4 flex-shrink-0">
                <a href="<%= application.cccdUrl %>" target="_blank" class="font-medium text-indigo-600 hover:text-indigo-500"> Xem </a>
              </div>
            </li>
            <% if (application.incomeProofUrl) { %>
            <li class="pl-3 pr-4 py-3 flex items-center justify-between text-sm">
              <div class="w-0 flex-1 flex items-center">
                <svg class="flex-shrink-0 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M8 4a3 3 0 00-3 3v4a5 5 0 0010 0V7a1 1 0 112 0v4a7 7 0 11-14 0V7a5 5 0 0110 0v4a3 3 0 11-6 0V7a1 1 0 012 0v4a1 1 0 102 0V7a3 3 0 00-3-3z" clip-rule="evenodd" />
                </svg>
                <span class="ml-2 flex-1 w-0 truncate"> Chứng minh thu nhập </span>
              </div>
              <div class="ml-4 flex-shrink-0">
                <a href="<%= application.incomeProofUrl %>" target="_blank" class="font-medium text-indigo-600 hover:text-indigo-500"> Xem </a>
              </div>
            </li>
            <% } %>
            <% if (application.contractUrl) { %>
            <li class="pl-3 pr-4 py-3 flex items-center justify-between text-sm">
              <div class="w-0 flex-1 flex items-center">
                <svg class="flex-shrink-0 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M8 4a3 3 0 00-3 3v4a5 5 0 0010 0V7a1 1 0 112 0v4a7 7 0 11-14 0V7a5 5 0 0110 0v4a3 3 0 11-6 0V7a1 1 0 012 0v4a1 1 0 102 0V7a3 3 0 00-3-3z" clip-rule="evenodd" />
                </svg>
                <span class="ml-2 flex-1 w-0 truncate"> Hợp đồng </span>
              </div>
              <div class="ml-4 flex-shrink-0">
                <a href="<%= application.contractUrl %>" target="_blank" class="font-medium text-indigo-600 hover:text-indigo-500"> Xem </a>
              </div>
            </li>
            <% } %>
          </ul>
        </dd>
      </div>
      <% if (application.status === 'REJECTED') { %>
      <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 bg-red-50">
        <dt class="text-sm font-medium text-red-500">Lý do từ chối</dt>
        <dd class="mt-1 text-sm text-red-900 sm:mt-0 sm:col-span-2 font-bold"><%= reasonLabels[application.reasonCode] || application.reasonCode %></dd>
      </div>
      <% if (application.note) { %>
      <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 bg-red-50 border-t border-red-100">
        <dt class="text-sm font-medium text-red-500">Ghi chú của Admin</dt>
        <dd class="mt-1 text-sm text-red-900 sm:mt-0 sm:col-span-2"><%= application.note %></dd>
      </div>
      <% } %>
      <% } %>
    </dl>
  </div>
</div>

<% if (application.status === 'PENDING') { %>
<div class="bg-white shadow sm:rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h3 class="text-lg leading-6 font-medium text-gray-900">Quyết định phê duyệt</h3>
    <div class="mt-5 sm:flex sm:items-center">
      <!-- APPROVE FORM -->
      <form action="/admin/<%= application.id %>/action" method="POST" class="mr-4">
        <input type="hidden" name="action" value="APPROVE">
        <button type="submit" class="inline-flex items-center justify-center px-4 py-2 border border-transparent font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 sm:text-sm shadow-sm transition duration-150 ease-in-out cursor-pointer">
          Phê duyệt hồ sơ
        </button>
      </form>

      <!-- REJECT BUTTON to toggle form -->
      <button type="button" onclick="document.getElementById('rejectForm').classList.toggle('hidden')" class="inline-flex items-center justify-center px-4 py-2 border border-transparent font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 sm:text-sm shadow-sm transition duration-150 ease-in-out cursor-pointer">
        Từ chối hồ sơ...
      </button>
    </div>

    <!-- REJECT FORM (Hidden by default) -->
    <form id="rejectForm" action="/admin/<%= application.id %>/action" method="POST" class="hidden mt-6 border-t border-gray-200 pt-6">
      <input type="hidden" name="action" value="REJECT">
      <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        <div class="sm:col-span-3">
          <label for="reasonCode" class="block text-sm font-medium text-gray-700">Mã lý do từ chối</label>
          <div class="mt-1">
            <select id="reasonCode" name="reasonCode" required class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border cursor-pointer">
              <option value="">Chọn lý do...</option>
              <% reasonCodes.forEach(code => { %>
                <option value="<%= code %>"><%= reasonLabels[code] %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="sm:col-span-6">
          <label for="note" class="block text-sm font-medium text-gray-700">Ghi chú (Không bắt buộc)</label>
          <div class="mt-1">
            <textarea id="note" name="note" rows="3" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border border-gray-300 rounded-md p-2"></textarea>
          </div>
        </div>
      </div>
      <div class="mt-4">
        <button type="submit" class="inline-flex items-center justify-center px-4 py-2 border border-transparent font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 sm:text-sm shadow-sm cursor-pointer">
          Xác nhận từ chối
        </button>
      </div>
    </form>
  </div>
</div>
<% } %>

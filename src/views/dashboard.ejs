<!-- PAGE HEADER -->
<div class="mb-5 sm:mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
  <div>
    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">Danh sách hồ sơ vay</h1>
    <p class="mt-1 text-sm text-slate-500">Quản lý và phê duyệt hồ sơ vay của khách hàng</p>
  </div>
  <!-- Realtime badge -->
  <span id="realtime-badge" class="self-start sm:self-auto inline-flex items-center gap-1.5 text-xs font-medium bg-green-50 text-green-700 px-3 py-1.5 rounded-full border border-green-200">
    <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
    Cập nhật realtime
  </span>
</div>

<!-- TABLE CARD -->
<div class="bg-white shadow-sm rounded-xl border border-slate-200 overflow-hidden">
  <!-- Mobile: cuộn ngang (overflow-x-auto theo UX guideline) -->
  <div class="table-wrapper">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th scope="col" class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider whitespace-nowrap">Mã hồ sơ</th>
          <th scope="col" class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider whitespace-nowrap">Khách hàng</th>
          <!-- Ẩn cột này trên màn hình rất nhỏ, hiện lại từ sm trở lên -->
          <th scope="col" class="hidden sm:table-cell px-4 sm:px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider whitespace-nowrap">Số tiền / Kỳ hạn</th>
          <th scope="col" class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider whitespace-nowrap">Trạng thái</th>
          <!-- Ẩn Ngày tạo trên mobile, hiện từ md trở lên -->
          <th scope="col" class="hidden md:table-cell px-4 sm:px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider whitespace-nowrap">Ngày tạo</th>
          <th scope="col" class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">
            <span class="sr-only">Hành động</span>
          </th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-slate-100">
        <% if (applications.length === 0) { %>
          <tr>
            <td colspan="6" class="px-6 py-12 text-center">
              <!-- Empty state -->
              <svg class="mx-auto h-10 w-10 text-slate-300 mb-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
              <p class="text-sm font-medium text-slate-500">Không tìm thấy hồ sơ nào.</p>
              <p class="text-xs text-slate-400 mt-1">Hồ sơ mới sẽ xuất hiện ở đây khi có người gửi yêu cầu.</p>
            </td>
          </tr>
        <% } %>
        <% applications.forEach(app => { %>
          <tr class="hover:bg-indigo-50/40 transition-colors duration-150 cursor-pointer" onclick="window.location='/admin/<%= app.id %>'">
            <!-- Mã hồ sơ: truncate để không vỡ layout -->
            <td class="px-4 sm:px-6 py-3 sm:py-4">
              <span class="text-xs sm:text-sm font-mono font-medium text-indigo-600 truncate block max-w-[7rem] sm:max-w-xs" title="<%= app.id %>">
                <%= app.id.substring(0, 8) %>...
              </span>
            </td>
            <!-- Tên & SĐT -->
            <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
              <div class="text-sm font-semibold text-slate-900"><%= app.customerName %></div>
              <div class="text-xs text-slate-500 mt-0.5"><%= app.phone %></div>
            </td>
            <!-- Số tiền & kỳ hạn (hidden on mobile) -->
            <td class="hidden sm:table-cell px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
              <div class="text-sm font-semibold text-slate-900"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(app.amount) %></div>
              <div class="text-xs text-slate-500 mt-0.5"><%= app.term %> tháng</div>
            </td>
            <!-- Trạng thái -->
            <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
              <% if (app.status === 'PENDING') { %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-semibold rounded-full bg-amber-100 text-amber-800 border border-amber-200">
                  <span class="w-1.5 h-1.5 bg-amber-500 rounded-full"></span>
                  <span class="hidden xs:inline">CHỜ</span> XỬ LÝ
                </span>
              <% } else if (app.status === 'APPROVED') { %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-semibold rounded-full bg-emerald-100 text-emerald-800 border border-emerald-200">
                  <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
                  DUYỆT
                </span>
              <% } else { %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-semibold rounded-full bg-red-100 text-red-800 border border-red-200">
                  <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" /></svg>
                  TỪ CHỐI
                </span>
              <% } %>
            </td>
            <!-- Ngày tạo (hidden on mobile) -->
            <td class="hidden md:table-cell px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-xs text-slate-500">
              <%= app.createdAt.toLocaleString('vi-VN') %>
            </td>
            <!-- Nút hành động -->
            <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-right" onclick="event.stopPropagation()">
              <a href="/admin/<%= app.id %>" class="inline-flex items-center gap-1 text-xs sm:text-sm font-semibold text-indigo-600 hover:text-indigo-800 cursor-pointer">
                Chi tiết
                <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" /></svg>
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- PAGINATION -->
  <% if (totalPages > 1) { %>
    <div class="border-t border-slate-200 bg-slate-50 px-4 sm:px-6 py-3">
      <!-- Mobile: stacked layout -->
      <div class="flex flex-col xs:flex-row items-center justify-between gap-3">
        <p class="text-xs sm:text-sm text-slate-600 order-2 xs:order-1">
          Trang <span class="font-semibold text-slate-900"><%= currentPage %></span>
          / <span class="font-semibold text-slate-900"><%= totalPages %></span>
          &mdash; tổng <span class="font-semibold text-slate-900"><%= total %></span> hồ sơ
        </p>
        <nav class="flex items-center gap-1.5 order-1 xs:order-2" aria-label="Điều hướng trang">
          <% if (currentPage > 1) { %>
            <a href="?page=<%= currentPage - 1 %>" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs sm:text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 cursor-pointer shadow-sm">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" /></svg>
              Trước
            </a>
          <% } %>
          <!-- Số trang hiện tại -->
          <span class="inline-flex items-center px-3 py-1.5 text-xs sm:text-sm font-semibold text-white bg-indigo-600 border border-indigo-600 rounded-lg shadow-sm">
            <%= currentPage %>
          </span>
          <% if (currentPage < totalPages) { %>
            <a href="?page=<%= currentPage + 1 %>" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs sm:text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 cursor-pointer shadow-sm">
              Sau
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" /></svg>
            </a>
          <% } %>
        </nav>
      </div>
    </div>
  <% } %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const eventSource = new EventSource('/admin/events');

    eventSource.onmessage = (event) => {
      const application = JSON.parse(event.data);
      showToast('Hồ sơ mới', `Nhận từ ${application.customerName} với số tiền ${new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(application.amount)}`);
      setTimeout(() => { window.location.reload(); }, 2500);
    };

    eventSource.onerror = () => {
      const badge = document.getElementById('realtime-badge');
      if (badge) {
        badge.className = 'self-start sm:self-auto inline-flex items-center gap-1.5 text-xs font-medium bg-slate-100 text-slate-500 px-3 py-1.5 rounded-full border border-slate-200';
        badge.innerHTML = '<span class="w-1.5 h-1.5 bg-slate-400 rounded-full"></span> Mất kết nối';
      }
    };

    function showToast(title, message) {
      const container = document.getElementById('toast-container');
      if (!container) return;

      const toast = document.createElement('div');
      toast.className = 'w-full bg-white shadow-xl rounded-xl pointer-events-auto ring-1 ring-slate-900/5 overflow-hidden transform transition-all duration-300 ease-out translate-y-4 opacity-0';

      toast.innerHTML = `
        <div class="p-4">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-green-100 flex items-center justify-center">
              <svg class="h-4 w-4 text-green-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-slate-900">${title}</p>
              <p class="mt-0.5 text-xs text-slate-500 leading-relaxed">${message}</p>
            </div>
            <button class="flex-shrink-0 text-slate-400 hover:text-slate-600 cursor-pointer focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded" onclick="this.closest('[data-toast]').remove()" aria-label="Đóng thông báo">
              <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
              </svg>
            </button>
          </div>
        </div>
      `;
      toast.setAttribute('data-toast', '');
      container.appendChild(toast);

      requestAnimationFrame(() => {
        toast.classList.remove('translate-y-4', 'opacity-0');
      });

      setTimeout(() => {
        toast.classList.add('opacity-0', 'translate-y-4');
        setTimeout(() => toast.remove(), 300);
      }, 5000);
    }
  });
</script>
